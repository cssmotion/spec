{
  "$schema": "https://cssmotion.dev/schema/1.0.0/manifest.json",
  "specVersion": "1.0.0",

  "identity": {
    "id": "confetti-burst",
    "name": "Confetti Burst",
    "description": "A celebratory confetti explosion with colourful particles. Ideal for success states, onboarding completion screens, and reward moments.",
    "tags": ["celebration", "confetti", "success", "onboarding", "reward", "particles"],
    "category": "feedback",
    "generator": "CSSMotion Studio 1.0.0",
    "createdAt": "2026-03-17T10:00:00Z",
    "updatedAt": "2026-03-17T10:00:00Z",
    "revision": 1
  },

  "attribution": {
    "author": "Mushfau Saeed",
    "organization": "CSSMotion",
    "email": "mushfau@cssmotion.dev",
    "url": "https://cssmotion.dev",
    "license": "CC-BY-4.0"
  },

  "playback": {
    "duration": 1200,
    "iterationCount": 1,
    "direction": "normal",
    "fillMode": "forwards",
    "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "autoplay": true,
    "triggers": {
      "hover": false,
      "click": true,
      "inView": true,
      "scroll": false
    },
    "intermission": 0
  },

  "dimensions": {
    "width": 400,
    "height": 400,
    "aspectRatio": "1/1",
    "scalingBehavior": "contain"
  },

  "theming": {
    "colorScheme": ["light", "dark"],
    "tokens": [
      {
        "name": "--cssm-primary-color",
        "type": "color",
        "defaultValue": "#FF6B6B",
        "description": "Primary particle colour (warm tones)",
        "group": "colors",
        "required": false
      },
      {
        "name": "--cssm-secondary-color",
        "type": "color",
        "defaultValue": "#4ECDC4",
        "description": "Secondary particle colour (cool tones)",
        "group": "colors",
        "required": false
      },
      {
        "name": "--cssm-accent-color",
        "type": "color",
        "defaultValue": "#FFE66D",
        "description": "Accent particle colour (highlight tones)",
        "group": "colors",
        "required": false
      },
      {
        "name": "--cssm-duration-scale",
        "type": "number",
        "defaultValue": "1",
        "description": "Multiplier for overall animation duration. 0.5 = twice as fast, 2 = twice as slow.",
        "group": "timing",
        "required": false
      },
      {
        "name": "--cssm-particle-size",
        "type": "length",
        "defaultValue": "8px",
        "description": "Diameter of each confetti particle.",
        "group": "shape",
        "required": false
      },
      {
        "name": "--cssm-spread-radius",
        "type": "length",
        "defaultValue": "120px",
        "description": "Maximum distance particles travel from the burst origin.",
        "group": "shape",
        "required": false
      }
    ],
    "variants": [
      {
        "id": "dark",
        "name": "Dark Mode",
        "file": "variants/dark.css",
        "mediaQuery": "(prefers-color-scheme: dark)"
      },
      {
        "id": "monochrome",
        "name": "Monochrome",
        "file": "variants/monochrome.css",
        "mediaQuery": null
      },
      {
        "id": "compact",
        "name": "Compact (200×200)",
        "file": "variants/compact.css",
        "mediaQuery": null
      }
    ]
  },

  "accessibility": {
    "reducedMotionBehavior": "static",
    "reducedMotionFile": null,
    "flashRisk": "none",
    "seizureRisk": false,
    "wcagLevel": "AA"
  },

  "technical": {
    "cssFeatures": ["@keyframes", "@property", "clip-path", "filter"],
    "scrollDriven": false,
    "viewTransition": false,
    "requiresJS": false,
    "minBrowserSupport": {
      "chrome": "111",
      "firefox": "116",
      "safari": "16.4",
      "edge": "111"
    }
  },

  "assets": {
    "svg": "animation.svg",
    "css": "animation.css",
    "preview": {
      "thumbnail": "preview/thumbnail.png",
      "animated": "preview/preview.gif"
    }
  },

  "custom": {}
}
